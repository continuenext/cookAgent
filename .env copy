# 应用配置
# ================== 必要参数说明 ==================
# • LLM_API_KEY / LLM_BASE_URL / LLM_MODEL：主聊天模型的凭据与地址，必须按实际账号配置。
# • EMBEDDING_API_KEY / EMBEDDING_BASE_URL / EMBEDDING_MODEL：向量化服务的凭据，Milvus/知识库检索依赖于此。
# • VISION_API_KEY / IMAGE_GENERATION_API_KEY：若需图片理解或生成，需替换为有效密钥，否则保持为空。
# • 数据库连接信息（DATABASE_URL、MILVUS_HOST、NEO4J_URI 等）须与 docker-compose 或自建环境一致，否则相关功能无法启动。
# ==================================================
APP_NAME=GustoBot
APP_VERSION=0.1.0
DEBUG=True

# API配置
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000


# LLM 服务配置(用于文本生成和问答)
LLM_PROVIDER=openai
LLM_MODEL=qwen-max-2025-01-25
LLM_API_KEY= # 需要自行到阿里云百炼创建自己的 apikey 填入
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TEMPERATURE=0.1 # 生成文本的随机程度，范围0-2，数值越大越随机
LLM_MAX_TOKENS=2048

# 视觉模型配置（用于图像分析）
VISION_API_KEY=# 需要自行到阿里云百炼创建自己的 apikey 填入
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_MODEL=qwen3.5-flash

# 图像生成模型配置（用于生成图片）
IMAGE_GENERATION_API_KEY= # 需要自行到阿里云百炼创建自己的 apikey 填入
IMAGE_GENERATION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
IMAGE_GENERATION_MODEL=qwen-image
IMAGE_GENERATION_SIZE=1024x1024

# Milvus向量数据库配置
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=recipes
MILVUS_INDEX_TYPE=HNSW
MILVUS_METRIC_TYPE=COSINE

# Embedding 服务配置(用于向量生成)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_API_KEY= # 需要自行到阿里云百炼创建自己的 apikey 填入
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_DIMENSION=1024

# Reranker 服务配置(用于精排)
RERANK_ENABLED=true
RERANK_PROVIDER=custom
RERANK_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services
RERANK_ENDPOINT=/rerank/text-rerank/text-rerank
RERANK_MODEL=qwen3-rerank
RERANK_API_KEY= # 需要自行到阿里云百炼创建自己的 apikey 填入
RERANK_MAX_CANDIDATES=20
RERANK_TOP_N=6
RERANK_TIMEOUT=30
RERANK_SCORE_FUSION_ALPHA=0.5

# Redis配置
REDIS_URL=redis://localhost:6379/0

# 数据库配置 使用 MySQL
DATABASE_URL=mysql+pymysql://recipe_user:recipepass@localhost:13306/recipe_db

# Neo4j 配置
NEO4J_URI=bolt://localhost:17687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j
NEO4J_DEFAULT_GRAPH_QUERY=MATCH (a)-[r]-(b) RETURN a, r, b LIMIT 100

# Agent配置
MAX_ITERATIONS=10 # Agent执行的最大迭代次数，防止无限循环
AGENT_TIMEOUT=300
# Agent对话记忆保留的用户轮数（正整数；小于等于0表示保留全部历史）
GUSTOBOT_MEMORY_TURNS=5

# 本地文件接入的最大体积（MB）
FILE_UPLOAD_MAX_MB=10

# CORS配置（逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5500,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:5500

# Ollama配置
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Mem0 记忆层配置（启用后 Agent 可跨会话记住用户偏好）
MEM0_ENABLED=false
MEM0_SEARCH_LIMIT=5
